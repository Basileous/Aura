{
  "version": 2,
  "builds": [
    {
      "src": "aura/wsgi.py",
      "use": "@vercel/python"
    }
  ],
    "builds": [
      {
        "src": "api/wsgi.py",
        "use": "@vercel/python",
        "config": { "maxLambdaSize": "50mb", "runtime": "python3.9" }
      }
    ],
    "routes": [
      {
        "src": "/(.*)",
        "dest": "api/wsgi.py"
      }
    ]
}
